# ============================================================
# VegasDelRio - Monorepo .gitignore
# ============================================================

# ---- Python (Backend) ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ---- Node.js (Frontend) ----
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Variables de entorno ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ---- Archivos de ejemplo de env (SÍ se versionan) ----
!.env.example

# ---- IDEs y Editores ----
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Testing ----
htmlcov/
.coverage
.coverage.*
.pytest_cache/
coverage/

# ---- PDFs generados ----
generated_pdfs/

# ---- Celery ----
celerybeat-schedule
celerybeat.pid

# ---- Supabase ----
supabase/.temp/
