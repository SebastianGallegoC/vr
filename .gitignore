# ============================================================
# VegasDelRio - Monorepo .gitignore
# ============================================================

# ---- Python (Backend) ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
# Archivo vacío creado por error en Windows
nul
# package-lock.json erróneo en el backend Python
apps/backend/package-lock.json

# ---- Node.js (Frontend) ----
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# ---- Variables de entorno ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ---- Archivos de ejemplo de env (SÍ se versionan) ----
!.env.example
!**/.env.example

# ---- IDEs y Editores ----
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Testing ----
htmlcov/
.coverage
.coverage.*
.pytest_cache/
coverage/
# Vitest / Jest
/apps/frontend/coverage/

# ---- Logs ----
*.log
logs/

# ---- PDFs generados ----
generated_pdfs/
apps/backend/generated_pdfs/

# ---- Celery ----
celerybeat-schedule
celerybeat.pid

# ---- Supabase ----
supabase/.temp/

# ---- Docker ----
*.tar
docker-compose.override.yml

# ---- Archivos de sistema ----
*.pem
*.key
*.crt
