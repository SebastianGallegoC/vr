# ============================================================
# VegasDelRio Backend - Variables de Entorno (Ejemplo)
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# cp .env.example .env

# ---- Aplicación ----
APP_NAME=VegasDelRio
APP_ENV=development
DEBUG=true
SECRET_KEY=cambiar-por-una-clave-segura-de-32-caracteres
API_V1_PREFIX=/api/v1

# ---- Supabase (Base de Datos) ----
# Conexión async para la aplicación (Session Mode - Puerto 5432)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Conexión síncrona para migraciones (Session Mode - Puerto 5432)
DATABASE_URL_DIRECT=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ---- Supabase (Auth & API) ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxx

# ---- Redis ----
# URL general de Redis (también usado para caché futuro / rate-limiting)
REDIS_URL=redis://localhost:6379/0

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- Servicio de Email ----
EMAIL_PROVIDER=smtp
# Para SMTP genérico:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM_NAME=Vegas del Río
SMTP_FROM_EMAIL=administracion@vegasdelrio.com

# Para Resend (alternativa):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxx

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3500"]
