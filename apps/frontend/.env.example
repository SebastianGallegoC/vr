# ============================================================
# VegasDelRio Frontend - Variables de Entorno (Ejemplo)
# ============================================================
# Copia este archivo como .env.local
# cp .env.example .env.local
#
# IMPORTANTE: Todas las variables aquí llevan el prefijo NEXT_PUBLIC_
# lo que significa que son PÚBLICAS y visibles en el navegador.
# NUNCA pongas claves secretas (service_role_key, passwords, etc.) aquí.

# ---- Supabase ----
# URL y clave anónima (pública) de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxx

# ---- Backend API ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
